# Порт HTTP API Audioray
PORT=3000

# Whisper.cpp server (worker, модель в памяти)
WHISPER_SERVER_HOST=127.0.0.1
WHISPER_SERVER_PORT=8081
WHISPER_SERVER_STARTUP_MS=120000

# Модель в audioray/models/
WHISPER_MODEL=ggml-large-v3-turbo.bin

# Сколько слов предыдущего текста передавать в --prompt
WHISPER_CONTEXT_WORDS=30

# Ollama — выжимка встречи
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=deepseek-r1:14b
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT_MS=300000
