# Порт HTTP API Aura (internal worker)
PORT=4000

# URL публичного backend
BACKEND_URL=http://localhost:5000

# Общий токен для internal API (backend ↔ aura)
INTERNAL_API_TOKEN=dev-internal-token

# URL сервиса распознавания речи (Audioray)
AUDIORAY_URL=http://localhost:3000/api/whisper/transcribe

# Бот
BOT_DEFAULT_NAME=Аура
BOT_CHUNK_INTERVAL_MS=6000
