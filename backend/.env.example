# HTTP API
PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=briefer
# true только для локальной разработки; в prod — миграции TypeORM
DB_SYNCHRONIZE=true
# Автозапуск миграций при старте (staging/prod)
DB_MIGRATE=false

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Auth: SMS OTP (в dev код также в ответе API и в логах)
AUTH_DEV_EXPOSE_OTP=true
OTP_TTL_SEC=300
AUTH_ENCRYPTION_KEY=dev-encryption-key-32chars!!

# TOTP (Google Authenticator и др.)
TOTP_ISSUER=Briefer

# Aura internal worker
AURA_URL=http://localhost:4000
INTERNAL_API_TOKEN=dev-internal-token

# Audioray (STT + выжимка через Ollama)
AUDIORAY_URL=http://localhost:3000

# Redis + BullMQ (очередь выжимок)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# CORS для frontend (dev)
CORS_ORIGIN=http://localhost:5173
